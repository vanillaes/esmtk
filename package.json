{
  "name": "@vanillaes/esmtk",
  "version": "0.24.1",
  "description": "ES Module Toolkit",
  "keywords": [
    "ecmascript",
    "esm",
    "esmodules",
    "cli",
    "developer-tools",
    "jsdoc",
    "fs",
    "cp",
    "copy",
    "rm",
    "remove"
  ],
  "repository": "https://github.com/vanillaes/esmtk",
  "author": "Evan Plaice <evanplaice@gmail.com> (https://evanplaice.com/)",
  "license": "MIT",
  "type": "module",
  "bin": {
    "esmtk": "bin/esmtk.js"
  },
  "exports": {
    ".": {
      "types": "./src/index.d.ts",
      "default": "./src/index.js"
    },
    "./cp": {
      "types": "./src/cp.d.ts",
      "default": "./src/cp.js"
    },
    "./rm": {
      "types": "./src/rm.d.ts",
      "default": "./src/rm.js"
    }
  },
  "scripts": {
    "test": "./bin/esmtk.js test",
    "lint": "./bin/esmtk.js lint",
    "types": "./bin/esmtk.js types src/index.js",
    "bundle": "./bin/esmtk.js bundle --platform=node src/index.js src/index.esm.js",
    "minify": "./bin/esmtk.js minify --platform=node src/index.js src/index.min.js",
    "typings": "./bin/esmtk.js typings src/index.js",
    "clean": "./bin/esmtk.js clean --typings",
    "preview": "./bin/esmtk.js preview",
    "preversion": "npm run test && npm run lint && npm run types",
    "postversion": "git push --follow-tags"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "@vanillaes/tape-es": "^3.0.3",
    "commander": "^14.0.3",
    "standard": "^17.1.2"
  },
  "devDependencies": {
    "@types/json5": "^0.0.30",
    "@types/node": "^25.5.0"
  }
}
