{
  "name": "@vanillaes/esmtk",
  "version": "2.2.3",
  "description": "ES Module Toolkit",
  "keywords": [
    "ecmascript",
    "esm",
    "esmodules",
    "typescript",
    "cli",
    "developer-tools",
    "jsdoc",
    "test",
    "lint",
    "type",
    "build",
    "clean",
    "preview"
  ],
  "repository": "https://github.com/vanillaes/esmtk",
  "author": "Evan Plaice <evanplaice@gmail.com> (https://evanplaice.com/)",
  "license": "MIT",
  "type": "module",
  "bin": {
    "esmtk": "bin/esmtk.js"
  },
  "exports": {
    ".": {
      "import": "./src/index.js",
      "types": "./src/index.d.ts"
    }
  },
  "scripts": {
    "esmtk": "./bin/esmtk.js",
    "test": "./bin/esmtk.js test",
    "lint": "./bin/esmtk.js lint",
    "type": "./bin/esmtk.js type --types node && ./bin/esmtk.js type --types node bin/esmtk.js",
    "build": "./bin/esmtk.js typings --types node",
    "clean": "./bin/esmtk.js clean --typings",
    "preview": "./bin/esmtk.js preview",
    "preversion": "npm run test && npm run lint && npm run type",
    "version": "npm run clean && npm run build && git add **/*.d.ts",
    "postversion": "git push --follow-tags"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "@vanillaes/lint-es": "^1.0.11",
    "@vanillaes/tape-es": "^4.0.12",
    "commander": "^14.0.3"
  },
  "devDependencies": {
    "@types/json5": "^0.0.30",
    "@types/node": "^25.5.0"
  },
  "lint": {
    "ignore": [
      "**/__tests__/**"
    ]
  }
}
