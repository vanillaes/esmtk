{
  "name": "@vanillaes/esmtk",
  "version": "1.7.0",
  "description": "ES Module Toolkit",
  "keywords": [
    "ecmascript",
    "esm",
    "esmodules",
    "typescript",
    "cli",
    "developer-tools",
    "jsdoc",
    "fs",
    "cp",
    "copy",
    "rm",
    "remove"
  ],
  "repository": "https://github.com/vanillaes/esmtk",
  "author": "Evan Plaice <evanplaice@gmail.com> (https://evanplaice.com/)",
  "license": "MIT",
  "type": "module",
  "bin": {
    "esmtk": "bin/esmtk.js"
  },
  "exports": {
    ".": {
      "import": "./src/index.js",
      "types": "./src/index.d.ts"
    },
    "./cp": {
      "import": "./src/cp.js",
      "types": "./src/cp.d.ts"
    },
    "./rm": {
      "import": "./src/rm.js",
      "types": "./src/rm.d.ts"
    }
  },
  "scripts": {
    "esmtk": "./bin/esmtk.js",
    "test": "./bin/esmtk.js test",
    "lint": "./bin/esmtk.js lint",
    "type": "./bin/esmtk.js type --module nodenext src/index.js && ./bin/esmtk.js type bin/esmtk.js --module nodenext",
    "bundle": "./bin/esmtk.js bundle --platform=node src/index.js src/index.esm.js",
    "minify": "./bin/esmtk.js minify --platform=node src/index.js src/index.min.js",
    "typings": "./bin/esmtk.js typings --module nodenext src/index.js",
    "clean": "./bin/esmtk.js clean --typings",
    "preview": "./bin/esmtk.js preview",
    "preversion": "npm run test && npm run lint && npm run type",
    "postversion": "git push --follow-tags"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "@vanillaes/lint-es": "^1.0.0",
    "@vanillaes/tape-es": "^4.0.7",
    "commander": "^14.0.3"
  },
  "devDependencies": {
    "@types/json5": "^0.0.30",
    "@types/node": "^25.5.0"
  },
  "lint": {
    "ignore": [
      "**/__tests__/**"
    ]
  }
}
