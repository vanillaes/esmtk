{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Version",
            "type": "node",
            "request": "launch",
            "skipFiles": [
                "<node_internals>/**"
            ],
            "program": "${workspaceFolder}/bin/esmtk.js",
            "cwd": "${workspaceFolder}",
            "args": ["--version"],
            "console": "integratedTerminal",
        },
        {
            "name": "Lint",
            "type": "node",
            "request": "launch",
            "skipFiles": [
                "<node_internals>/**"
            ],
            "program": "${workspaceFolder}/bin/esmtk.js",
            "cwd": "${workspaceFolder}",
            "args": ["lint"],
            "console": "integratedTerminal",
        },
        {
            "name": "Types",
            "type": "node",
            "request": "launch",
            "skipFiles": [
                "<node_internals>/**"
            ],
            "program": "${workspaceFolder}/bin/esmtk.js",
            "cwd": "${workspaceFolder}",
            "args": ["types", "./src/index.js"],
            "console": "integratedTerminal",
        },
        {
            "name": "Typings",
            "type": "node",
            "request": "launch",
            "skipFiles": [
                "<node_internals>/**"
            ],
            "program": "${workspaceFolder}/bin/esmtk.js",
            "cwd": "${workspaceFolder}",
            "args": ["typings", "./src/index.js"],
            "console": "integratedTerminal",
        },
        {
            "name": "Bundle",
            "type": "node",
            "request": "launch",
            "skipFiles": [
                "<node_internals>/**"
            ],
            "program": "${workspaceFolder}/bin/esmtk.js",
            "cwd": "${workspaceFolder}",
            "args": ["bundle", "--platform=node", "./src/index.js", "./dist/index.js"],
            "console": "integratedTerminal",
        },
        {
            "name": "Minify",
            "type": "node",
            "request": "launch",
            "skipFiles": [
                "<node_internals>/**"
            ],
            "program": "${workspaceFolder}/bin/esmtk.js",
            "cwd": "${workspaceFolder}",
            "args": ["minify", "--sourcemap", "--platform=node", "./src/index.js", "./dist/index.min.js"],
            "console": "integratedTerminal",
        },
        {
            "name": "CommonJS",
            "type": "node",
            "request": "launch",
            "skipFiles": [
                "<node_internals>/**"
            ],
            "program": "${workspaceFolder}/bin/esmtk.js",
            "cwd": "${workspaceFolder}",
            "args": ["commonjs", "--platform=node", "./src/index.js", "./dist/index.cjs"],
            "console": "integratedTerminal",
        },
        {
            "name": "CopyFileToFile",
            "type": "node",
            "request": "launch",
            "skipFiles": [
                "<node_internals>/**"
            ],
            "program": "${workspaceFolder}/bin/esmtk.js",
            "cwd": "${workspaceFolder}",
            "args": ["cp", "./test/cp/test1.txt", "./test/cp2/test1.txt"],
            "console": "integratedTerminal",
        },
        {
            "name": "CopyFileToFolder",
            "type": "node",
            "request": "launch",
            "skipFiles": [
                "<node_internals>/**"
            ],
            "program": "${workspaceFolder}/bin/esmtk.js",
            "cwd": "${workspaceFolder}",
            "args": ["cp", "./test/cp/test1.txt", "./test/cp2/test1.txt"],
            "console": "integratedTerminal",
        },
                {
            "name": "CopyGlobToFolder",
            "type": "node",
            "request": "launch",
            "skipFiles": [
                "<node_internals>/**"
            ],
            "program": "${workspaceFolder}/bin/esmtk.js",
            "cwd": "${workspaceFolder}",
            "args": ["cp", "./test/cp/*.js", "./test/cp2/"],
            "console": "integratedTerminal",
        },
        {
            "name": "CopyFileToFile - Error source doesn't exist",
            "type": "node",
            "request": "launch",
            "skipFiles": [
                "<node_internals>/**"
            ],
            "program": "${workspaceFolder}/bin/esmtk.js",
            "cwd": "${workspaceFolder}",
            "args": ["cp", "./test/cp/testx.txt", "./test/cp2/"],
            "console": "integratedTerminal",
        },
        {
            "name": "CopyFileToFile - Error source is a directory",
            "type": "node",
            "request": "launch",
            "skipFiles": [
                "<node_internals>/**"
            ],
            "program": "${workspaceFolder}/bin/esmtk.js",
            "cwd": "${workspaceFolder}",
            "args": ["cp", "./test/cp/", "./test/cp2/test1.txt"],
            "console": "integratedTerminal",
        },
        {
            "name": "CopyFileToFile - Error target directory doesn't exist",
            "type": "node",
            "request": "launch",
            "skipFiles": [
                "<node_internals>/**"
            ],
            "program": "${workspaceFolder}/bin/esmtk.js",
            "cwd": "${workspaceFolder}",
            "args": ["cp", "./test/cp/test1.txt", "./test/cpx/"],
            "console": "integratedTerminal",
        },
        {
            "name": "CopyFolderRecursively",
            "type": "node",
            "request": "launch",
            "skipFiles": [
                "<node_internals>/**"
            ],
            "program": "${workspaceFolder}/bin/esmtk.js",
            "cwd": "${workspaceFolder}",
            "args": ["cp", "-r", "./test/cp/", "./test/cp2"],
            "console": "integratedTerminal",
        },
        {
            "name": "CopyMultipleFiles",
            "type": "node",
            "request": "launch",
            "skipFiles": [
                "<node_internals>/**"
            ],
            "program": "${workspaceFolder}/bin/esmtk.js",
            "cwd": "${workspaceFolder}",
            "args": ["cp", "./test/cp/test1.txt", "./test/cp/test1.js", "./test/cp/test2.txt", "./test/cp/test2.js", "./test/cp2/"],
            "console": "integratedTerminal",
        },
        {
            "name": "CopyMultipleFiles - Error file doesn't exist",
            "type": "node",
            "request": "launch",
            "skipFiles": [
                "<node_internals>/**"
            ],
            "program": "${workspaceFolder}/bin/esmtk.js",
            "cwd": "${workspaceFolder}",
            "args": ["cp", "./test/cp/test1.ts", "./test/cp/test1.js", "./test/cp/test2.txt", "./test/cp/test2.js", "./test/cp2/"],
            "console": "integratedTerminal",
        },
        {
            "name": "CopyMultipleGlobs",
            "type": "node",
            "request": "launch",
            "skipFiles": [
                "<node_internals>/**"
            ],
            "program": "${workspaceFolder}/bin/esmtk.js",
            "cwd": "${workspaceFolder}",
            "args": ["cp", "./test/cp/*.txt", "./test/cp/*.js", "./test/cp2/"],
            "console": "integratedTerminal",
        },
        {
            "name": "CopyMultipleGlobs - Error glob not found",
            "type": "node",
            "request": "launch",
            "skipFiles": [
                "<node_internals>/**"
            ],
            "program": "${workspaceFolder}/bin/esmtk.js",
            "cwd": "${workspaceFolder}",
            "args": ["cp", "./test/cp/*.ts", "./test/cp/*.js", "./test/cp2/"],
            "console": "integratedTerminal",
        },
        {
            "name": "CopyMultipleMixed",
            "type": "node",
            "request": "launch",
            "skipFiles": [
                "<node_internals>/**"
            ],
            "program": "${workspaceFolder}/bin/esmtk.js",
            "cwd": "${workspaceFolder}",
            "args": ["cp", "./test/cp/test1.txt", "./test/cp/test2.txt", "./test/cp/*.js", "./test/cp2/"],
            "console": "integratedTerminal",
        },
        {
            "name": "RemoveFile",
            "type": "node",
            "request": "launch",
            "skipFiles": [
                "<node_internals>/**"
            ],
            "program": "${workspaceFolder}/bin/esmtk.js",
            "cwd": "${workspaceFolder}",
            "args": ["rm", "./test/cp2/test1.txt"],
            "console": "integratedTerminal",
        },
        {
            "name": "RemoveFile - Error file is a directory",
            "type": "node",
            "request": "launch",
            "skipFiles": [
                "<node_internals>/**"
            ],
            "program": "${workspaceFolder}/bin/esmtk.js",
            "cwd": "${workspaceFolder}",
            "args": ["rm", "./test/cp2/"],
            "console": "integratedTerminal",
        },
        {
            "name": "RemoveGlob",
            "type": "node",
            "request": "launch",
            "skipFiles": [
                "<node_internals>/**"
            ],
            "program": "${workspaceFolder}/bin/esmtk.js",
            "cwd": "${workspaceFolder}",
            "args": ["rm", "./test/cp2/*.js"],
            "console": "integratedTerminal",
        },
        {
            "name": "RemoveGlob - Error glob not found",
            "type": "node",
            "request": "launch",
            "skipFiles": [
                "<node_internals>/**"
            ],
            "program": "${workspaceFolder}/bin/esmtk.js",
            "cwd": "${workspaceFolder}",
            "args": ["rm", "./test/cp2/*.ts"],
            "console": "integratedTerminal",
        },
        {
            "name": "RemoveDirectory",
            "type": "node",
            "request": "launch",
            "skipFiles": [
                "<node_internals>/**"
            ],
            "program": "${workspaceFolder}/bin/esmtk.js",
            "cwd": "${workspaceFolder}",
            "args": ["rm", "-r", "./test/cp2/"],
            "console": "integratedTerminal",
        },
        {
            "name": "RemoveMultipleFiles",
            "type": "node",
            "request": "launch",
            "skipFiles": [
                "<node_internals>/**"
            ],
            "program": "${workspaceFolder}/bin/esmtk.js",
            "cwd": "${workspaceFolder}",
            "args": ["rm", "./test/cp2/test1.txt", "./test/cp2/test2.txt"],
            "console": "integratedTerminal",
        },
        {
            "name": "RemoveMultipleGlobs",
            "type": "node",
            "request": "launch",
            "skipFiles": [
                "<node_internals>/**"
            ],
            "program": "${workspaceFolder}/bin/esmtk.js",
            "cwd": "${workspaceFolder}",
            "args": ["rm", "./test/cp2/*.txt", "./test/cp2/*.js"],
            "console": "integratedTerminal",
        },
        {
            "name": "RemoveMultipleGlobs - Error glob not found",
            "type": "node",
            "request": "launch",
            "skipFiles": [
                "<node_internals>/**"
            ],
            "program": "${workspaceFolder}/bin/esmtk.js",
            "cwd": "${workspaceFolder}",
            "args": ["rm", "./test/cp2/*.txt", "./test/cp2/*.ts"],
            "console": "integratedTerminal",
        },
        {
            "name": "RemoveMultipleMixed",
            "type": "node",
            "request": "launch",
            "skipFiles": [
                "<node_internals>/**"
            ],
            "program": "${workspaceFolder}/bin/esmtk.js",
            "cwd": "${workspaceFolder}",
            "args": ["rm", "./test/cp2/test1.txt", "./test/cp2/*.js"],
            "console": "integratedTerminal",
        },
        {
            "name": "Clean --bundle",
            "type": "node",
            "request": "launch",
            "skipFiles": [
                "<node_internals>/**"
            ],
            "program": "${workspaceFolder}/bin/esmtk.js",
            "cwd": "${workspaceFolder}",
            "args": ["clean", "--bundle"],
            "console": "integratedTerminal",
        },
        {
            "name": "Clean --bundle w/ override",
            "type": "node",
            "request": "launch",
            "skipFiles": [
                "<node_internals>/**"
            ],
            "program": "${workspaceFolder}/bin/esmtk.js",
            "cwd": "${workspaceFolder}",
            "args": ["clean", "--bundle", "**/*.js"],
            "console": "integratedTerminal",
        },
        {
            "name": "Clean --bundle w/ Error",
            "type": "node",
            "request": "launch",
            "skipFiles": [
                "<node_internals>/**"
            ],
            "program": "${workspaceFolder}/bin/esmtk.js",
            "cwd": "${workspaceFolder}",
            "args": ["clean", "--bundle", "**/*.mjs"],
            "console": "integratedTerminal",
        },
        {
            "name": "Clean --minify",
            "type": "node",
            "request": "launch",
            "skipFiles": [
                "<node_internals>/**"
            ],
            "program": "${workspaceFolder}/bin/esmtk.js",
            "cwd": "${workspaceFolder}",
            "args": ["clean", "--minify"],
            "console": "integratedTerminal",
        },
        {
            "name": "Clean --typings",
            "type": "node",
            "request": "launch",
            "skipFiles": [
                "<node_internals>/**"
            ],
            "program": "${workspaceFolder}/bin/esmtk.js",
            "cwd": "${workspaceFolder}",
            "args": ["clean", "--typings"],
            "console": "integratedTerminal",
        },
        {
            "name": "Clean All",
            "type": "node",
            "request": "launch",
            "skipFiles": [
                "<node_internals>/**"
            ],
            "program": "${workspaceFolder}/bin/esmtk.js",
            "cwd": "${workspaceFolder}",
            "args": ["clean", "--bundle", "--minify", "--typings"],
            "console": "integratedTerminal",
